{
  "name": "example",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "analyze": "better-convex analyze",
    "build": "next build",
    "codegen": "better-convex codegen",
    "convex:dev": "convex dev --until-success --run init && better-convex dev",
    "convex:logs": "bun convex logs --history 50",
    "dev": "mprocs",
    "dev:app": "next dev --port 3005",
    "gen": "next typegen",
    "gen:auth": "bunx @better-auth/cli generate -y --output convex/functions/authSchema.ts --config convex/functions/generated.ts",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "migrate:create": "better-convex migrate create",
    "migrate:down": "better-convex migrate down",
    "migrate:status": "better-convex migrate status",
    "migrate:up": "better-convex migrate up",
    "reset": "better-convex reset --yes && sleep 3 && convex run init",
    "seed": "convex run seed:seed",
    "start": "next start",
    "studio": "bun convex dashboard",
    "sync": "better-convex env sync --auth",
    "sync:force": "better-convex env sync --auth --force",
    "sync:jwks": "convex run auth:getLatestJwks | convex env set JWKS",
    "sync:plate": "node tooling/sync-plate.cjs",
    "sync:rotate": "convex run auth:rotateKeys | convex env set JWKS",
    "typecheck": "tsc --noEmit && bun run typecheck:convex",
    "typecheck:convex": "tsc --noEmit --project convex/tsconfig.json",
    "typecheck:watch": "tsc --noEmit --watch"
  },
  "dependencies": {
    "@convex-dev/react-query": "0.1.0",
    "@convex-dev/resend": "0.2.3",
    "@hookform/resolvers": "5.2.2",
    "@react-email/components": "1.0.8",
    "@react-email/render": "2.0.4",
    "@t3-oss/env-nextjs": "0.13.10",
    "better-convex": "workspace:*",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "common-tags": "1.8.2",
    "convex": "1.32.0",
    "date-fns": "4.1.0",
    "embla-carousel-react": "8.6.0",
    "input-otp": "1.4.2",
    "jotai-x": "2.3.3",
    "lucide-react": "0.575.0",
    "next-themes": "0.4.6",
    "nuqs": "2.8.8",
    "radix-ui": "latest",
    "react-day-picker": "9.13.2",
    "react-hook-form": "7.71.2",
    "react-resizable-panels": "3.0.6",
    "recharts": "2.15.4",
    "sonner": "2.0.7",
    "superjson": "2.2.6",
    "tailwind-merge": "3.5.0",
    "ts-essentials": "10.1.1",
    "tsx": "4.21.0",
    "type-fest": "5.4.4",
    "use-debounce": "10.1.0",
    "vaul": "1.1.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@types/bun": "latest",
    "@types/common-tags": "1.8.4",
    "babel-plugin-react-compiler": "1.0.0",
    "mprocs": "^0.8.3",
    "tailwindcss": "4.2.1",
    "tw-animate-css": "1.4.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
